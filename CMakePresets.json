{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21 },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (MSVC x64 + vcpkg)",
      "description": "Visual Studio 2026 x64, vcpkg toolchain, Qt via QT_DIR",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{QT_DIR}"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug", "configurePreset": "default", "configuration": "Debug" },
    { "name": "release", "configurePreset": "default", "configuration": "Release" }
  ]
}
